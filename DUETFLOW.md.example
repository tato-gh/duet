---
# Duet が起動する Erlang ノード名。snameで起動
# 省略時は duet
node_name: "duet"

# git diff 監視モード（Mode A）
diff_watch:
  enabled: true
  # LLM に使うコマンド
  command: "codex app-server"
  # 差分取得コマンド
  diff_command: "git diff HEAD"
  # ポーリング間隔（ms）
  poll_interval: 1000
  # 未追跡ファイルを差分に含めるか
  include_untracked: false
  # 承認ポリシー（string または object）
  # デフォルトは "never"（全操作を自動承認）
  # 例: "never" | "on-request" | "on-failure" | "untrusted" | {"granular": {...}}
  approval_policy: "never"
  # thread/start の sandbox
  # read-only | workspace-write | danger-full-access
  thread_sandbox: "read-only"
  # turn/start の sandboxPolicy（明示指定）
  turn_sandbox_policy:
    type: "readOnly"
    networkAccess: false
  # diff_watch モードのシステムプロンプト
  prompt: |
    ファイルの変更を見て、気軽に一言コメントしてください。

# erpc 経由で AI と対話するモード（Mode B）
# 各エントリが独立した AI（独自スレッド）を持つ
erpc_channel:
  - name: "positive"
    enabled: true
    command: "codex app-server"
    # role を省略すると初回ターンに何も付与しない
    role: "ポジティブでハイテンションな雑談相手"
    approval_policy: "never"
    thread_sandbox: "read-only"
    turn_sandbox_policy:
      type: "readOnly"
      networkAccess: false

  - name: "negative"
    enabled: true
    command: "codex app-server"
    role: "ネガティブでローテンションな雑談相手"
    # sessionベース承認フローを使う設定例
    approval_policy: "never"
    thread_sandbox: "workspace-write"
    turn_sandbox_policy:
      type: "workspaceWrite"
      networkAccess: true
---
